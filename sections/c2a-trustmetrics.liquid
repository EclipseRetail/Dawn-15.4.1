{% liquid
  assign columns = section.blocks.size
  if columns < 2
    assign columns = 2
  endif
%}

<section class="c2a-trustmetrics-section color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="c2a-trustmetrics-section__header c2a-trustmetrics-section__header--{{ section.settings.header_alignment }}">
        {% if section.settings.subheading != blank %}
          <p class="c2a-trustmetrics-section__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="c2a-trustmetrics-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="image-text-carousel">
      <div class="image-text-carousel-track">
        {% for block in section.blocks %}
          <article class="image-text-card" {{ block.shopify_attributes }}>
            <div class="c2a-trustmetrics__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '360, 540, 720, 960, 1200',
                    sizes: '(min-width: 990px) 33vw, 100vw',
                    class: 'c2a-trustmetrics__image'
                }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'c2a-trustmetrics__image c2a-trustmetrics__image--placeholder' }}
              {% endif %}
            </div>

            <div class="c2a-trustmetrics__content c2a-trustmetrics__content--{{ block.settings.text_alignment }}">
              {% if block.settings.title != blank %}
                <h3 class="c2a-trustmetrics__title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="c2a-trustmetrics__text rte">
                  {{ block.settings.text }}
                </div>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    let myIndex = 0;

    function carouselSlide() {
      const track = document.querySelector(".image-text-carousel-track");
      const cards = document.querySelectorAll(".image-text-card");

      console.log("track:", track);
      console.log("cards:", cards);

      if (!track || cards.length === 0) return;

      if (window.innerWidth <= 768) {
        myIndex++;
        if (myIndex >= cards.length) {
          myIndex = 0;
        }

        track.style.transform = "translateX(-" + (myIndex * 100) + "%)";
      } else {
        track.style.transform = "none";
      }
    }

    setInterval(carouselSlide, 2000);
  });
</script>

{% style %}

  /* @keyframes fade {
    from {opacity: .4}
    to {opacity: 1}
  }
    
  @-webkit-keyframes fade {
    from {opacity: .4}
    to {opacity: 1}
  }
    
  .c2a-trustmetrics-grid article.image-text-card.fade {
    -webkit-animation-name: fade;
    -webkit-animation-duration: 1.5s;
    animation-name: fade;
    animation-duration: 1.5s;
    width: 100%;
  }

  article.image-text-card {
      display: none;
  }


  @media only screen and (max-width: 749px) {
    .c2a-trustmetrics-grid article.image-text-card:not(:nth-child(2n)) {
      display: none;
    }
  } */

  .image-text-carousel {
    overflow: hidden;
    width: 100%;
  }

  .image-text-carousel-track {
    display: flex;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .image-text-card {
    flex: 0 0 100%;
    box-sizing: border-box;
  }

  /* Desktop: show all 3 */
  @media screen and (min-width: 769px) {
    .image-text-carousel {
      overflow: visible;
    }

    .image-text-carousel-track {
      display: flex;
      transform: none !important;
      transition: none;
      gap: 20px; /* optional */
    }

    .image-text-card {
      flex: 1 1 33.333%;
    }
  }


  .c2a-trustmetrics-grid article.image-text-card {
      height: 18rem;
      position: relative;
      margin: auto;
      /* max-width: 1440px; */
  }

  .c2a-trustmetrics-section {
    border-bottom: 1px solid rgba(var(--color-background-contrast));
    border-top: 1px solid rgba(var(--color-background-contrast));
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (min-width: 750px) {
    .c2a-trustmetrics-section {
      margin: 0 10rem;
    }
  }

  .c2a-trustmetrics-section__header {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 48rem;
  }

  .c2a-trustmetrics-section__subheading {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 1.2rem;
    opacity: 0.7;
  }

  .c2a-trustmetrics-section__heading {
    margin: 0;
  }

  .c2a-trustmetrics__content--left,
  .c2a-trustmetrics-section__header--left {
    text-align: left;
    margin-left: 0;
    margin-right: auto;
  }

  .c2a-trustmetrics__content--center,
  .c2a-trustmetrics-section__header--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .c2a-trustmetrics__content--right,
  .c2a-trustmetrics-section__header--right {
    text-align: right;
    margin-left: auto;
    margin-right: 0;
  }

  .c2a-trustmetrics-grid {
    display: grid;
    gap: 2rem;
  }

  .c2a-trustmetrics-grid--2,
  .c2a-trustmetrics-grid--3 {
    grid-template-columns: 1fr;
  }

  .image-text-card {
    background: rgba(var(--color-background), 1);
    overflow: hidden;
    height: 100%;
  }

  .c2a-trustmetrics__image {
    display: block;
    height: 100%;
    max-height: 7.5rem;
    opacity: 0.8;
    padding: 1.5rem 0;
    width: 100%;
  }

  .c2a-trustmetrics__content {
    padding: 2rem;
  }

  .c2a-trustmetrics__title {
    fontsize: 1.4rem;
    margin: 0 0 1rem;
  }
  
  .c2a-trustmetrics__text {
    font-size: 1.2rem;
  }
  
  .c2a-trustmetrics__text > *:first-child {
    margin-top: 0;
  }

  .c2a-trustmetrics__text > *:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    article.image-text-card.fade {
      display: inline-block !important;
    }

    .c2a-trustmetrics-grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .c2a-trustmetrics-grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .c2a-trustmetrics__content {
      padding: 2.4rem;
      padding-bottom: 0;
    }

    .C2A.top-banner .mySlides.fade {
      display: inline-block !important;
      text-align: center;
      width: 33.33%;
    }
  }
{% endstyle %}

{% schema %}
