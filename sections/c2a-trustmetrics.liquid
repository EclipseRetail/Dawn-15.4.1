{% liquid
  assign columns = section.blocks.size
  if columns < 2
    assign columns = 2
  endif
%}

<section class="c2a-trustmetrics-section color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="c2a-trustmetrics-section__header">
        {% if section.settings.subheading != blank %}
          <p class="c2a-trustmetrics-section__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="c2a-trustmetrics-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="c2a-trustmetrics-grid c2a-trustmetrics-grid--{{ columns }}">
      {% for block in section.blocks %}
        <article class="image-text-card" {{ block.shopify_attributes }}>
          <div class="image-text-card__media">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200',
                  sizes: '(min-width: 990px) 33vw, 100vw',
                  class: 'image-text-card__image'
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'image-text-card__image image-text-card__image--placeholder' }}
            {% endif %}
          </div>

          <div class="image-text-card__content">
            {% if block.settings.title != blank %}
              <h3 class="image-text-card__title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="image-text-card__text rte">
                {{ block.settings.text }}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  .c2a-trustmetrics-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .c2a-trustmetrics-section__header {
    text-align: center;
    margin: 0 auto 3rem;
    max-width: 48rem;
  }

  .c2a-trustmetrics-section__subheading {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 1.2rem;
    opacity: 0.7;
  }

  .c2a-trustmetrics-section__heading {
    margin: 0;
  }

  .c2a-trustmetrics-grid {
    display: grid;
    gap: 2rem;
  }

  .c2a-trustmetrics-grid--2,
  .c2a-trustmetrics-grid--3 {
    grid-template-columns: 1fr;
  }

  .image-text-card {
    background: rgba(var(--color-background), 1);
    /* border-radius: 1.6rem; */
    overflow: hidden;
    /* box-shadow: 0 0 0 0.1rem rgba(var(--color-foreground), 0.08); */
    height: 100%;
  }

  /* .image-text-card__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  } */

  .image-text-card__image {
    width: 100%;
    height: 100%;
    display: block;
    /* object-fit: cover; */
    opacity: 0.8;
  }

  .image-text-card__content {
    padding: 2rem;
  }

  .image-text-card__title {
    margin: 0 0 1rem;
  }

  .image-text-card__text > *:first-child {
    margin-top: 0;
  }

  .image-text-card__text > *:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 750px) {
    .c2a-trustmetrics-grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .c2a-trustmetrics-grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .image-text-card__content {
      padding: 2.4rem;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "C2A Trustmetrics",
  "tag": "section",
  "class": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "C2A Trustmetrics"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Card title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your text here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C2A Trustmetrics",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
