<style>
.mpn-related-item.is-active {
  border: 2px solid black;
}
</style>
{% assign current_mpn = product.metafields['shopify--facts']['mpn'].value %}

{% for p in collections.all.products %}
  {% assign p_mpn = p.metafields['shopify--facts']['mpn'].value %}

  {% if p_mpn == current_mpn %}
    <a href="{{ p.url }}" class="mpn-related-item {% if p.id == product.id %}is-active{% endif %}">
      <img src="{{ p.featured_image | image_url: width: 50 }}" alt="{{ p.title }}" loading="lazy">
    </a>
  {% endif %}
{% endfor %}

<style>
.mpn-related-item.is-active {
  border: 2px solid black;
}
</style>
{% assign current_mpn = product.metafields['shopify--facts']['mpn'].value %}
{% assign current_collection = product.collections.first %}

{% if current_collection %}
  {% paginate current_collection.products by 100 %}
    {% for p in current_collection.products %}
      {% assign p_mpn = p.metafields['shopify--facts']['mpn'].value %}
      {% if p_mpn == current_mpn %}
        <a href="{{ p.url }}" class="mpn-related-item {% if p.id == product.id %}is-active{% endif %}">
          <img
            src="{{ p.featured_image | image_url: width: 100 }}"
            alt="{{ p.title }}"
            loading="lazy"
          >
        </a>
      {% endif %}
    {% endfor %}
  {% endpaginate %}
{% endif %}


