<style>
.mpn-related-item.is-active {
  border: 1px solid black;
}
.mpn-switcher {
    display: flex;
}
.mpn-switcher-item {
    margin-right: 1rem;
}
</style>
{% assign grouped = product.metafields['custom']['grouped_products'].value %}
<div class="mpn-switcher">
  {% for p in grouped %}
    <a href="{{ p.url }}" class="mpn-switcher-item">
      <img src="{{ p.featured_image | image_url: width: 50 }}" alt="{{ p.title }}" loading="lazy" class="mpn-related-item {% if p.id == product.id %}is-active{% endif %}">
    </a>
  {% endfor %}
</div>