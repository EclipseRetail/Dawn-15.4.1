{% doc %}
  @prompt
    i want a simple 1px divider
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: {{ block.settings.spacing_top }}px auto {{ block.settings.spacing_bottom }}px;
  }

  .ai-divider-line-{{ ai_gen_id }} {
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    border: none;
    margin: 0;
  }
{% endstyle %}

<div class="ai-divider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <hr class="ai-divider-line-{{ ai_gen_id }}">
</div>

{% schema %}
{
  "name": "Divider",
  "settings": [
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Divider"
    }
  ]
}
{% endschema %}
